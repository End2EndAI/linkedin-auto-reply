{
  "manifest_version": 3,
  "name": "LinkedIn Reply Assistant",
  "version": "1.1.0",
  "description": "Assistant intelligent pour répondre aux messages des recruteurs sur LinkedIn",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/messaging/*",
        "https://www.linkedin.com/in/*"
      ],
      "js": ["classifier.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
